generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  username  String     @unique
  password  String?
  image     String?
  role      UserRole   @default(USER)
  xp        Int        @default(0)
  level     Int        @default(1)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  progress  Progress[]
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  levels      Level[]
}

model Level {
  id          String     @id @default(cuid())
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  number      Int
  name        String
  description String?
  xpRequired  Int        @default(0)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  questions   Question[]
  progress    Progress[]

  @@unique([categoryId, number])
}

model Question {
  id          String   @id @default(cuid())
  levelId     String
  level       Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  question    String
  code        String?
  options     String[]
  correctIdx  Int
  explanation String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId   String
  level     Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  completed Boolean  @default(false)
  score     Int?
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, levelId])
}
